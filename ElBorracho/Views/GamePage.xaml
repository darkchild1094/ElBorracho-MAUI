<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="ElBorracho.Views.GamePage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ElBorracho.Models"
             xmlns:converters="clr-namespace:ElBorracho.Converters"
             BackgroundColor="#160810"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:NullToBoolConverter    x:Key="NullToBoolConverter"/>
            <converters:NotNullToBoolConverter x:Key="NotNullToBoolConverter"/>
            <converters:ZeroToBoolConverter    x:Key="ZeroToBoolConverter"/>
            <Style x:Key="ActionBtn" TargetType="Button">
                <Setter Property="FontSize"       Value="14"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CornerRadius"   Value="14"/>
                <Setter Property="Padding"        Value="16,0"/>
                <Setter Property="HeightRequest"  Value="50"/>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid x:Name="RootGrid">

        <!-- ══════════ MAIN CONTENT ══════════ -->
        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Padding="0">

            <!-- TOP BAR -->
            <Grid Grid.Row="0" BackgroundColor="#22101A"
                  Padding="12,44,16,12"
                  ColumnDefinitions="44,*,Auto">

                <Button Grid.Column="0"
                        Text="☰" FontSize="22"
                        TextColor="#F0E4D0" BackgroundColor="Transparent"
                        Clicked="OnMenuClicked"
                        WidthRequest="44" HeightRequest="44" Padding="0"/>

                <Label Grid.Column="1" Text="LOTERÍA"
                       FontSize="20" FontAttributes="Bold"
                       TextColor="#D4175A"
                       HorizontalOptions="Center" VerticalOptions="Center"/>

                <!-- Cards remaining badge -->
                <Border Grid.Column="2"
                        BackgroundColor="#3D1D2A"
                        StrokeThickness="0"
                        Padding="10,6">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
                        <Label Text="{Binding RemainingCount}"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="#C4940C" VerticalOptions="Center"/>
                        <Label Text="/" FontSize="12" TextColor="#704858"
                               VerticalOptions="Center"/>
                        <Label Text="54" FontSize="12" TextColor="#704858"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>
            </Grid>

            <!-- PROGRESS BAR -->
            <Grid Grid.Row="1" BackgroundColor="#22101A" Padding="16,0,16,10">
                <Grid RowDefinitions="Auto,4" RowSpacing="0">
                    <ProgressBar Grid.Row="1"
                                 x:Name="ProgressBar"
                                 Progress="0"
                                 ProgressColor="#D4175A"
                                 BackgroundColor="#3D1D2A"
                                 HeightRequest="4"/>
                </Grid>
            </Grid>

            <!-- CARD AREA -->
            <Grid Grid.Row="2" RowDefinitions="*,Auto" Padding="16,8,16,8">

                <!-- Card stack -->
                <Grid Grid.Row="0"
                      HorizontalOptions="Center" VerticalOptions="Center">

                    <Grid x:Name="CardStackArea"
                          WidthRequest="260" HeightRequest="360"
                          HorizontalOptions="Center" VerticalOptions="Center">

                        <!-- Ghost cards (deck effect) -->
                        <Border x:Name="Ghost5" BackgroundColor="#E8DFC5"
                                Stroke="#241208" StrokeThickness="2"
                                WidthRequest="240" HeightRequest="330"
                                HorizontalOptions="Center" VerticalOptions="Center"
                                Rotation="-11" TranslationX="-8" TranslationY="6">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                            <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.4"/></Border.Shadow>
                            <Image Source="el_gallo.jpg" Aspect="AspectFill" Opacity="0.3"/>
                        </Border>

                        <Border x:Name="Ghost4" BackgroundColor="#EDE5CC"
                                Stroke="#241208" StrokeThickness="2"
                                WidthRequest="240" HeightRequest="330"
                                HorizontalOptions="Center" VerticalOptions="Center"
                                Rotation="9" TranslationX="6" TranslationY="4">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                            <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.4"/></Border.Shadow>
                            <Image Source="la_luna.jpg" Aspect="AspectFill" Opacity="0.3"/>
                        </Border>

                        <Border x:Name="Ghost3" BackgroundColor="#F0E8D0"
                                Stroke="#241208" StrokeThickness="2"
                                WidthRequest="240" HeightRequest="330"
                                HorizontalOptions="Center" VerticalOptions="Center"
                                Rotation="-6" TranslationX="-4" TranslationY="2">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                            <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.4"/></Border.Shadow>
                            <Image Source="el_sol.jpg" Aspect="AspectFill" Opacity="0.3"/>
                        </Border>

                        <Border x:Name="Ghost2" BackgroundColor="#F3ECD8"
                                Stroke="#241208" StrokeThickness="2"
                                WidthRequest="240" HeightRequest="330"
                                HorizontalOptions="Center" VerticalOptions="Center"
                                Rotation="4" TranslationX="3" TranslationY="1">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                            <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.4"/></Border.Shadow>
                            <Image Source="el_borracho.jpg" Aspect="AspectFill" Opacity="0.3"/>
                        </Border>

                        <!-- Intro card (no game started) -->
                        <Border x:Name="IntroCard"
                                IsVisible="{Binding CurrentCard, Converter={StaticResource NullToBoolConverter}}"
                                BackgroundColor="#F5EDD6"
                                Stroke="#241208" StrokeThickness="2"
                                WidthRequest="240" HeightRequest="330"
                                HorizontalOptions="Center" VerticalOptions="Center"
                                Rotation="-2">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                            <Border.Shadow><Shadow Brush="Black" Offset="0,8" Radius="20" Opacity="0.65"/></Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCardTapped"/>
                                <PanGestureRecognizer PanUpdated="OnIntroPan"/>
                            </Border.GestureRecognizers>
                            <Grid RowDefinitions="*,Auto">
                                <Image Grid.Row="0" Source="intro.jpg"
                                       Aspect="AspectFill" HeightRequest="270"/>
                                <Grid Grid.Row="1" BackgroundColor="#160810" Padding="8,8">
                                    <Label Text="Toca para iniciar"
                                           TextColor="#F5EDD6"
                                           FontSize="15" FontAttributes="Bold"
                                           HorizontalTextAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Active card -->
                        <Border x:Name="CardFrame"
                                IsVisible="{Binding CurrentCard, Converter={StaticResource NotNullToBoolConverter}}"
                                BackgroundColor="#F5EDD6"
                                Stroke="#241208" StrokeThickness="2"
                                WidthRequest="240" HeightRequest="330"
                                HorizontalOptions="Center" VerticalOptions="Center">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                            <Border.Shadow><Shadow Brush="Black" Offset="0,8" Radius="20" Opacity="0.65"/></Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCardTapped"/>
                            </Border.GestureRecognizers>
                            <Grid RowDefinitions="*,Auto">
                                <Image Grid.Row="0"
                                       Source="{Binding CurrentCard.Imagen, StringFormat='{0}.jpg'}"
                                       Aspect="AspectFill" HeightRequest="270"/>
                                <Grid Grid.Row="1" BackgroundColor="#160810" Padding="8,8">
                                    <Label Text="{Binding CurrentCard.Nombre}"
                                           TextColor="#F5EDD6"
                                           FontSize="15" FontAttributes="Bold"
                                           HorizontalTextAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Border>

                    </Grid>
                </Grid>

                <!-- History -->
                <VerticalStackLayout Grid.Row="1" Spacing="6" Margin="0,4,0,0">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="HISTORIAL" FontSize="10" FontAttributes="Bold"
                               TextColor="#704858" Margin="2,0" VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="{Binding PlayedCards.Count, StringFormat='{0} cartas'}"
                               FontSize="10" TextColor="#704858" VerticalOptions="Center"/>
                    </Grid>
                    <ScrollView x:Name="HistScroll"
                                Orientation="Horizontal" HeightRequest="74">
                        <HorizontalStackLayout Spacing="6" Padding="4,0"
                            BindableLayout.ItemsSource="{Binding PlayedCards}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:Carta">
                                    <Border BackgroundColor="#F5EDD6"
                                            Stroke="#241208" StrokeThickness="1"
                                            WidthRequest="48" HeightRequest="66">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                                        <Border.Shadow><Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.3"/></Border.Shadow>
                                        <Image Source="{Binding Imagen, StringFormat='{0}.jpg'}"
                                               Aspect="AspectFill" Margin="2"/>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>
                    <Label Text="Aquí aparecerán las cartas jugadas" FontSize="11" TextColor="#4A2838"
                           IsVisible="{Binding PlayedCards.Count, Converter={StaticResource ZeroToBoolConverter}}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>

            <!-- ACTION BUTTONS -->
            <Grid Grid.Row="3"
                  ColumnDefinitions="54,*,Auto,Auto"
                  Padding="16,6,16,0" ColumnSpacing="10">

                <!-- Shuffle -->
                <Border Grid.Column="0"
                        BackgroundColor="#2E1520" StrokeThickness="0"
                        WidthRequest="54" HeightRequest="54">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                    <Button Text="🔀" FontSize="20"
                            TextColor="#F0E4D0" BackgroundColor="Transparent"
                            IsEnabled="{Binding CanShuffle}"
                            Command="{Binding ShuffleDeckCommand}"
                            Padding="0"/>
                </Border>

                <!-- Play/Pause (main action) -->
                <Button Grid.Column="1" x:Name="BtnPlay"
                        Text="{Binding PlayButtonText}"
                        BackgroundColor="#D4175A" TextColor="White"
                        Style="{StaticResource ActionBtn}"
                        IsEnabled="{Binding CanPlayPause}"
                        Command="{Binding ToggleAutoPlayCommand}">
                    <Button.Shadow>
                        <Shadow Brush="#D4175A" Offset="0,3" Radius="10" Opacity="0.35"/>
                    </Button.Shadow>
                </Button>

                <!-- Next -->
                <Button Grid.Column="2" Text="Sig. ▶"
                        BackgroundColor="#2E1520" TextColor="#F0E4D0"
                        Style="{StaticResource ActionBtn}"
                        IsEnabled="{Binding CanNext}"
                        Command="{Binding NextCardManualCommand}"/>

                <!-- Reset -->
                <Button Grid.Column="3" Text="↺ Nuevo"
                        BackgroundColor="#3D1D2A" TextColor="#F0E4D0"
                        Style="{StaticResource ActionBtn}"
                        IsEnabled="{Binding CanReset}"
                        Command="{Binding ResetGameCommand}"/>
            </Grid>

            <!-- Safe area bottom spacer -->
            <BoxView Grid.Row="4" HeightRequest="16" BackgroundColor="Transparent"/>
        </Grid>

        <!-- ══════════ SIDEBAR OVERLAY ══════════ -->
        <BoxView x:Name="SidebarOverlay" Color="#BB000000"
                 IsVisible="False" Opacity="0">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnOverlayTapped"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- SIDEBAR PANEL -->
        <Grid x:Name="SidebarPanel" BackgroundColor="#1A0C14"
              HorizontalOptions="Start" VerticalOptions="Fill"
              WidthRequest="300" TranslationX="-300"
              RowDefinitions="Auto,Auto,Auto,Auto,*,Auto"
              Padding="20,52,20,34">

            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="*,40" Margin="0,0,0,6">
                <VerticalStackLayout Grid.Column="0" Spacing="3">
                    <Label Text="Lotería El Borracho"
                           FontSize="17" FontAttributes="Bold" TextColor="#D4175A"/>
                    <Label Text="v1.0  ·  Clemente Jacq.  ·  🇲🇽"
                           FontSize="11" TextColor="#704858"/>
                </VerticalStackLayout>
                <Button Grid.Column="1" Text="✕" FontSize="16"
                        TextColor="#704858" BackgroundColor="Transparent"
                        Clicked="OnCloseSidebar"
                        WidthRequest="40" HeightRequest="40" Padding="0"/>
            </Grid>

            <BoxView Grid.Row="1" HeightRequest="1"
                     BackgroundColor="#22F0E4D0" Margin="0,10,0,18"/>

            <!-- Speed control -->
            <VerticalStackLayout Grid.Row="2" Spacing="10" Margin="0,0,0,24">
                <Label Text="⏱  VELOCIDAD ENTRE CARTAS"
                       FontSize="10" FontAttributes="Bold" TextColor="#704858"
                       CharacterSpacing="1"/>
                <Grid ColumnDefinitions="*,Auto">
                    <Label x:Name="LblSpeedName" Grid.Column="0"
                           Text="Normal" FontSize="16" FontAttributes="Bold"
                           TextColor="#F0E4D0"/>
                    <Border Grid.Column="1"
                            BackgroundColor="#2E1520" StrokeThickness="0"
                            Padding="8,4">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                        <Label x:Name="LblSpeedValue" Text="5 s"
                               FontSize="13" FontAttributes="Bold" TextColor="#C4940C"/>
                    </Border>
                </Grid>
                <Slider x:Name="SpeedSlider"
                        Minimum="0" Maximum="5" Value="2"
                        ThumbColor="#D4175A"
                        MinimumTrackColor="#D4175A"
                        MaximumTrackColor="#3D1D2A"
                        ValueChanged="OnSpeedChanged"/>
                <Grid ColumnDefinitions="*,*" Margin="2,0">
                    <Label Grid.Column="0" Text="⚡ Rápido" FontSize="10" TextColor="#704858"/>
                    <Label Grid.Column="1" Text="Lento 🐢" FontSize="10" TextColor="#704858"
                           HorizontalOptions="End"/>
                </Grid>
            </VerticalStackLayout>

            <BoxView Grid.Row="3" HeightRequest="1"
                     BackgroundColor="#22F0E4D0" Margin="0,0,0,16"/>

            <!-- Menu items -->
            <VerticalStackLayout Grid.Row="4" Spacing="10">

                <Border BackgroundColor="#2E1520" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <Button Text="🎴   Generador de tablas"
                            HorizontalOptions="Fill"
                            BackgroundColor="Transparent" TextColor="#F0E4D0"
                            FontSize="15" Padding="16,14"
                            HorizontalContentAlignment="Start"
                            Clicked="OnGeneradorClicked"/>
                </Border>

                <Border BackgroundColor="#2E1520" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <Button Text="🐛   Reportar un bug"
                            HorizontalOptions="Fill"
                            BackgroundColor="Transparent" TextColor="#F0E4D0"
                            FontSize="15" Padding="16,14"
                            HorizontalContentAlignment="Start"
                            Clicked="OnBugClicked"/>
                </Border>
            </VerticalStackLayout>

            <!-- Quit -->
            <Border Grid.Row="5" BackgroundColor="#5A1111" StrokeThickness="0" Margin="0,10,0,0">
                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                <Button Text="🚪   Salir del juego"
                        HorizontalOptions="Fill"
                        BackgroundColor="Transparent" TextColor="#FF8888"
                        FontSize="15" Padding="16,14"
                        HorizontalContentAlignment="Start"
                        Clicked="OnSalirClicked"/>
            </Border>

        </Grid>

    </Grid>
</ContentPage>
