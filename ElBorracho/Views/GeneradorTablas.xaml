<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="ElBorracho.Views.GeneradorTablasPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Generador de Tablas"
             BackgroundColor="#160810">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20">

        <!-- Título -->
        <VerticalStackLayout Grid.Row="0" Spacing="8" Margin="0,20,0,0">
            <Label Text="🎴 Generador de Tablas"
                   FontSize="24" FontAttributes="Bold"
                   TextColor="#D4175A" HorizontalOptions="Center"/>
            <Label Text="Genera tableros de lotería para tus jugadores"
                   FontSize="14" TextColor="#A07888"
                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
        </VerticalStackLayout>

        <!-- Control de cantidad -->
        <VerticalStackLayout Grid.Row="1"
                             VerticalOptions="Center"
                             HorizontalOptions="Center" Spacing="20">

            <Label Text="¿Cuántas tablas necesitas?"
                   FontSize="16" FontAttributes="Bold"
                   TextColor="#F0E4D0" HorizontalOptions="Center"/>

            <Grid ColumnDefinitions="50,100,50"
                  HorizontalOptions="Center" ColumnSpacing="12">
                <Button Grid.Column="0" Text="−" FontSize="22"
                        BackgroundColor="#2E1520" TextColor="#F0E4D0"
                        CornerRadius="12" WidthRequest="50" HeightRequest="50"
                        Clicked="OnDecrementar"/>
                <Label Grid.Column="1" x:Name="LblCantidad" Text="4"
                       FontSize="28" FontAttributes="Bold"
                       TextColor="#C4940C"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
                <Button Grid.Column="2" Text="+" FontSize="22"
                        BackgroundColor="#2E1520" TextColor="#F0E4D0"
                        CornerRadius="12" WidthRequest="50" HeightRequest="50"
                        Clicked="OnIncrementar"/>
            </Grid>

            <Label Text="Cada tabla tiene una cuadrícula 4×4 de cartas aleatorias"
                   FontSize="12" TextColor="#704858"
                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
        </VerticalStackLayout>

        <!-- Botón generar -->
        <Button Grid.Row="2" Text="🖨  Generar tablas"
                BackgroundColor="#D4175A" TextColor="White"
                FontSize="16" FontAttributes="Bold"
                CornerRadius="14" HeightRequest="54"
                Margin="0,0,0,20"
                Clicked="OnGenerarClicked"/>
    </Grid>
</ContentPage>